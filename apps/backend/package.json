{
  "name": "medusa-2.0-boilerplate-backend",
  "version": "0.0.2",
  "description": "A Prebaked Medusa 2.0 backend",
  "author": "Rasmus Puls",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build && node src/scripts/postBuild.js",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "ib": "init-backend",
    "start": "cd .medusa/server && medusa start --verbose",
    "dev": "medusa develop",
    "email:dev": "email dev --dir=../../packages/plugin-email/src/providers/email-notifications/templates --port=3002",
    "ruo:test-alert": "ts-node --transpile-only src/scripts/test-ruo-geo-alert.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "jest --testPathPattern=src/",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@calilean/plugin-bundles": "workspace:*",
    "@calilean/plugin-erp": "workspace:*",
    "@calilean/plugin-email": "workspace:*",
    "@calilean/plugin-invoices": "workspace:*",
    "@calilean/plugin-loyalty": "workspace:*",
    "@calilean/plugin-preorder": "workspace:*",
    "@calilean/plugin-qr-marketing": "workspace:*",
    "@calilean/plugin-reviews": "workspace:*",
    "@calilean/plugin-shipstation": "workspace:*",
    "@calilean/plugin-subscription": "workspace:*",
    "@medusajs/admin-sdk": "2.14.1",
    "@medusajs/admin-shared": "2.14.1",
    "@medusajs/cli": "2.14.1",
    "@medusajs/dashboard": "2.14.1",
    "@medusajs/draft-order": "2.14.1",
    "@medusajs/framework": "2.14.1",
    "@medusajs/icons": "2.14.1",
    "@medusajs/js-sdk": "2.14.1",
    "@medusajs/loyalty-plugin": "^2.14.1",
    "@medusajs/medusa": "2.14.1",
    "@medusajs/notification-sendgrid": "2.14.1",
    "@medusajs/payment-stripe": "2.14.1",
    "@medusajs/ui": "4.1.8",
    "@medusajs/workflow-engine-redis": "2.14.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@rokmohar/medusa-plugin-meilisearch": "1.3.5",
    "@sanity/client": "^7.22.0",
    "@segment/analytics-node": "^2.2.1",
    "@sentry/node": "^9.29.0",
    "@sentry/opentelemetry-node": "^7.114.0",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.2",
    "medusajs-launch-utils": "0.0.18",
    "multer": "2.0.2",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "ulid": "^2.4.0",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/orchestration": "2.14.1",
    "@medusajs/test-utils": "2.14.1",
    "@react-email/preview-server": "^5.1.0",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
