{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "package.json",
        "tsconfig.json",
        "next.config.js",
        "medusa-config.ts",
        "tailwind.config.js",
        "postcss.config.js"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".medusa/server/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "inputs": ["src/**"],
      "outputs": []
    },
    "test": {
      "inputs": ["src/**", "integration-tests/**"],
      "outputs": []
    },
    "seed": {
      "cache": false,
      "outputs": []
    }
  }
}
