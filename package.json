{
  "name": "calilean",
  "private": true,
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:dev": "turbo dev --filter=medusa-2.0-boilerplate-backend",
    "storefront:dev": "turbo dev --filter=medusa-next",
    "build:brand-book": "node docs/brand/brand-book/export_brand_book_pdf.js",
    "build:deck": "node docs/deliverables/pitch-deck/export_pdf.js",
    "build:docx": "python3 docs/utils/md_to_docx.py --all",
    "build:docx:clean": "python3 docs/utils/md_to_docx.py --clean",
    "build:all-docs": "npm run build:brand-book && npm run build:deck && npm run build:docx",
    "drive:push:all": "npm run build:docx && python3 docs/utils/sync_drive.py push --all",
    "drive:push:check": "python3 docs/utils/sync_drive.py push --all --check-conflicts",
    "drive:status": "python3 docs/utils/sync_drive.py status",
    "drive:check-conflicts": "python3 docs/utils/sync_drive.py check-conflicts"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.5.8",
      "protobufjs": "7.5.5",
      "@medusajs/core-flows": "2.14.1",
      "@medusajs/workflows-sdk": "2.14.1",
      "@medusajs/orchestration": "2.14.1"
    }
  },
  "devDependencies": {
    "puppeteer": "^24.42.0",
    "turbo": "^2.0.14"
  }
}
