    "@medusajs/cli": "2.14.1",
    "@medusajs/framework": "2.14.1",
    "@medusajs/medusa": "2.14.1",
    "@medusajs/test-utils": "2.14.1",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@medusajs/framework": "2.14.1",
    "@medusajs/medusa": "2.14.1"
  },
  "engines": {
    "node": ">=20"
  }
