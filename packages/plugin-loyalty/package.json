{
  "name": "@calilean/plugin-loyalty",
  "version": "0.1.0",
  "private": true,
  "description": "Loyalty points system plugin for CaliLean",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
